# ─────────────────────────────────────────────────────────────────────────────
# TodoClick Backend — variables de entorno (PLANTILLA)
# Copiá este archivo a `.env` y completá los valores reales AHÍ.
# NUNCA pongas credenciales reales en este archivo: `.env.example` SÍ se versiona.
# El `.env` está en .gitignore.
# ─────────────────────────────────────────────────────────────────────────────

# Servidor
NODE_ENV=development
PORT=8080
# Orígenes permitidos para CORS (separados por coma). En desarrollo se aceptan
# todos automáticamente; en producción poné acá el dominio web real.
CORS_ORIGINS=*

# Firebase Admin SDK
# Opción A (recomendada en local): ruta al JSON de la service account.
GOOGLE_APPLICATION_CREDENTIALS=./secrets/firebase-service-account.json
# Opción B (recomendada en cloud): pegar el JSON completo en una sola variable.
# FIREBASE_SERVICE_ACCOUNT_JSON=
FIREBASE_PROJECT_ID=tu-project-id

# Mercado Pago (Checkout Pro)
# Para el piloto usá las credenciales de PRUEBA (empiezan con TEST-...).
MP_ACCESS_TOKEN=TEST-xxxxxxxx-xxxxxxxx
MP_WEBHOOK_SECRET=                     # secreto para validar la firma del webhook
# URLs de retorno del checkout (opcionales; la app resuelve por polling).
MP_SUCCESS_URL=
MP_FAILURE_URL=
MP_PENDING_URL=
# URL pública del backend donde MP enviará las notificaciones (webhook)
MP_NOTIFICATION_URL=https://tu-tunel.ngrok-free.app/api/payments/webhook

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_UPLOAD_FOLDER=todoclick/products

# Correo Argentino — API MiCorreo (opcional; sin credenciales usa estimación por zona/peso)
# Base: TEST https://apitest.correoargentino.com.ar/micorreo/v1 · PROD https://api.correoargentino.com.ar/micorreo/v1
CORREO_ARGENTINO_API_BASE=https://apitest.correoargentino.com.ar/micorreo/v1
CORREO_ARGENTINO_USER=                 # usuario para POST /token (Basic Auth)
CORREO_ARGENTINO_PASSWORD=
CORREO_ARGENTINO_CUSTOMER_ID=          # customerId de MiCorreo (de /register o /users/validate)
CORREO_ARGENTINO_AGREEMENT=            # (compat) se usa como customerId si el anterior está vacío
# CPA de origen (depósito desde donde se despacha)
SHIPPING_ORIGIN_POSTAL_CODE=S2152
# Remitente/origen para dar de alta envíos (POST /shipping/import) — opcional
SHIPPING_ORIGIN_NAME=
SHIPPING_ORIGIN_PHONE=
SHIPPING_ORIGIN_CELLPHONE=
SHIPPING_ORIGIN_EMAIL=
SHIPPING_ORIGIN_STREET_NAME=
SHIPPING_ORIGIN_STREET_NUMBER=
SHIPPING_ORIGIN_FLOOR=
SHIPPING_ORIGIN_APARTMENT=
SHIPPING_ORIGIN_CITY=
SHIPPING_ORIGIN_PROVINCE_CODE=          # una letra (B=Buenos Aires, C=CABA, X=Córdoba, …)
